meta {
  name: Get next race info
  type: http
  seq: 4
}

get {
  url: https://api.jolpi.ca/ergast/f1/current/next/races/
  body: none
  auth: inherit
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: EXAMPLE
  
  request: {
    url: https://api.jolpi.ca/ergast/f1/current/next/races/
    method: GET
    mode: none
  }
  
  response: {
    headers: {
      server: nginx/1.28.0
      date: Mon, 16 Feb 2026 17:51:55 GMT
      content-type: application/json
      transfer-encoding: chunked
      connection: keep-alive
      vary: Accept, origin
      allow: GET, HEAD, OPTIONS
      expires: Mon, 16 Feb 2026 18:51:55 GMT
      cache-control: max-age=3600
      x-frame-options: DENY
      x-content-type-options: nosniff
      referrer-policy: same-origin
      cross-origin-opener-policy: same-origin
    }
  
    status: {
      code: 200
      text: OK
    }
  
    body: {
      type: json
      content: '''
        {
          "MRData": {
            "xmlns": "",
