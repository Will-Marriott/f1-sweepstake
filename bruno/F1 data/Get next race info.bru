                    "circuitName": "Albert Park Grand Prix Circuit",
                    "Location": {
                      "lat": "-37.8497",
                      "long": "144.968",
                      "locality": "Melbourne",
                      "country": "Australia"
                    }
                  },
                  "date": "2026-03-08",
                  "time": "04:00:00Z",
                  "FirstPractice": {
                    "date": "2026-03-06",
                    "time": "01:30:00Z"
                  },
                  "SecondPractice": {
                    "date": "2026-03-06",
                    "time": "05:00:00Z"
                  },
                  "ThirdPractice": {
